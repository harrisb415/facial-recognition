# dependencies
node_modules/

# build output
dist/
dist-ssr/

# Model weight files (scrfd_tiny.onnx, mobilefacenet.onnx, antispoof_tiny.onnx)
# ARE committed as of 2026-06-24 — sourced from InsightFace (buffalo_sc pack) and
# minivision-ai Silent-Face-Anti-Spoofing (via ONNX conversion). See
# public/models/manifest.json for per-model license terms (the SCRFD/MobileFaceNet
# weights are non-commercial-research-use only per InsightFace's stated
# license — read public/models/README.md before any commercial use). Models
# live under public/ (not a project-root models/) so `vite build` actually
# ships them — see FILE_MAP_AND_TODO.md §3 for why this matters. Any *other*
# files dropped into these directories (alternate exports, TF.js shards you
# generate locally, etc.) stay git-ignored by default — only the exact
# filenames manifest.json expects are tracked.
public/models/detector/*
!public/models/detector/.gitkeep
!public/models/detector/scrfd_tiny.onnx
public/models/embedder/*
!public/models/embedder/.gitkeep
!public/models/embedder/mobilefacenet.onnx
public/models/antispoof/*
!public/models/antispoof/.gitkeep
!public/models/antispoof/antispoof_tiny.onnx

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor/OS
.DS_Store
.vscode/*
!.vscode/extensions.json
*.local

# env
.env
.env.local
