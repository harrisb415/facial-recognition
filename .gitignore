# dependencies
node_modules/

# build output
dist/
dist-ssr/

# Model weight files (scrfd_tiny.onnx, mobilefacenet.onnx, antispoof_tiny.onnx)
# ARE committed as of 2026-06-24 — sourced from InsightFace (buffalo_sc pack) and
# minivision-ai Silent-Face-Anti-Spoofing (via ONNX conversion). See
# models/manifest.json for per-model license terms (the SCRFD/MobileFaceNet
# weights are non-commercial-research-use only per InsightFace's stated
# license — read models/README.md before any commercial use). Any *other*
# files dropped into these directories (alternate exports, TF.js shards you
# generate locally, etc.) stay git-ignored by default — only the exact
# filenames manifest.json expects are tracked.
models/detector/*
!models/detector/.gitkeep
!models/detector/scrfd_tiny.onnx
models/embedder/*
!models/embedder/.gitkeep
!models/embedder/mobilefacenet.onnx
models/antispoof/*
!models/antispoof/.gitkeep
!models/antispoof/antispoof_tiny.onnx

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor/OS
.DS_Store
.vscode/*
!.vscode/extensions.json
*.local

# env
.env
.env.local
