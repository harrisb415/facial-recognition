# dependencies
node_modules/

# build output
dist/
dist-ssr/

# model weight binaries — see models/README.md for how to source these.
# Intentionally NOT committed: large binary files, and conversion/license
# provenance should be verified by whoever places them, not assumed from git history.
# Everything under each model-task directory is ignored except the placeholder.
models/detector/*
!models/detector/.gitkeep
models/embedder/*
!models/embedder/.gitkeep
models/antispoof/*
!models/antispoof/.gitkeep

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor/OS
.DS_Store
.vscode/*
!.vscode/extensions.json
*.local

# env
.env
.env.local
